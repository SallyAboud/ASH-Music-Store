<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
  fx:controller="org.musicStore.gui.LoginController"
  style="-fx-background-color: #06060c;"
  prefWidth="900" prefHeight="620">

  <VBox alignment="CENTER" spacing="0">

    <!-- Logo Row -->
    <HBox alignment="CENTER" spacing="14">
      <StackPane>
        <Rectangle width="52" height="52" arcWidth="16" arcHeight="16"
          style="-fx-fill: linear-gradient(to bottom right, #c9a84c, #7c5cbf);" />
        <Label text="🎸" style="-fx-font-size: 24px;" />
      </StackPane>
      <VBox alignment="CENTER_LEFT" spacing="3">
        <Label text="ASH"
          style="-fx-font-family: 'Georgia'; -fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #e8e8f0;" />
        <Label text="ASH  STORE"
          style="-fx-font-size: 10px; -fx-text-fill: #c9a84c; -fx-font-weight: bold;" />
      </VBox>
    </HBox>

    <Region prefHeight="32" />

    <!-- Card -->
    <VBox spacing="18" maxWidth="400"
      style="-fx-background-color: #1e1035;
             -fx-border-color: rgba(201,168,76,0.22);
             -fx-border-radius: 20;
             -fx-background-radius: 20;
             -fx-border-width: 1;
             -fx-effect: dropshadow(gaussian, #000000, 60, 0.5, 0, 20);">
      <padding><Insets top="42" right="40" bottom="42" left="40" /></padding>

      <VBox spacing="4">
        <Label text="Welcome back"
          style="-fx-font-family: 'Georgia'; -fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #e8e8f0;" />
        <Label text="Sign in to continue your musical journey"
          style="-fx-font-size: 13px; -fx-text-fill: #6b6b85;" />
      </VBox>

      <!-- Email -->
      <VBox spacing="7">
        <Label text="EMAIL ADDRESS"
          style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #6b6b85;" />
        <TextField fx:id="emailField" promptText="name@example.com"
          style="-fx-padding: 13 16; -fx-background-radius: 12;
                 -fx-background-color: rgba(255,255,255,0.04);
                 -fx-border-color: rgba(255,255,255,0.09);
                 -fx-border-radius: 12; -fx-border-width: 1;
                 -fx-text-fill: #e8e8f0; -fx-prompt-text-fill: #3a3a55;
                 -fx-font-size: 14px;" />
      </VBox>

      <!-- Password -->
      <VBox spacing="7">
        <Label text="PASSWORD"
          style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #6b6b85;" />
        <HBox spacing="6" alignment="CENTER_LEFT">
          <PasswordField fx:id="passwordField" promptText="••••••••"
            HBox.hgrow="ALWAYS"
            style="-fx-padding: 13 16; -fx-background-radius: 12;
                   -fx-background-color: rgba(255,255,255,0.04);
                   -fx-border-color: rgba(255,255,255,0.09);
                   -fx-border-radius: 12; -fx-border-width: 1;
                   -fx-text-fill: #e8e8f0; -fx-prompt-text-fill: #3a3a55;
                   -fx-font-size: 14px;" />
          <TextField fx:id="passwordVisible" promptText="••••••••"
            HBox.hgrow="ALWAYS"
            style="-fx-padding: 13 16; -fx-background-radius: 12;
                   -fx-background-color: rgba(255,255,255,0.04);
                   -fx-border-color: rgba(255,255,255,0.09);
                   -fx-border-radius: 12; -fx-border-width: 1;
                   -fx-text-fill: #e8e8f0; -fx-prompt-text-fill: #3a3a55;
                   -fx-font-size: 14px;" />
          <Button fx:id="togglePasswordBtn" text="👁" onAction="#handleTogglePassword"
            style="-fx-background-color: rgba(255,255,255,0.05);
                   -fx-border-color: rgba(255,255,255,0.09);
                   -fx-border-radius: 10; -fx-background-radius: 10;
                   -fx-border-width: 1; -fx-cursor: hand;
                   -fx-font-size: 15px; -fx-padding: 10 14;
                   -fx-text-fill: #8b8ba0;" />
        </HBox>
      </VBox>

      <!-- Login Button -->
      <Button fx:id="loginButton" text="Sign In  →" onAction="#handleLogin"
        maxWidth="Infinity"
        style="-fx-background-color: linear-gradient(to right, #c9a84c, #9a7030);
               -fx-text-fill: #1a0a2e; -fx-font-weight: bold;
               -fx-font-size: 15px; -fx-padding: 14;
               -fx-background-radius: 12; -fx-cursor: hand;
               -fx-effect: dropshadow(gaussian, rgba(201,168,76,0.5), 20, 0, 0, 6);" />

      <!-- Divider -->
      <HBox alignment="CENTER" spacing="12">
        <Separator HBox.hgrow="ALWAYS" />
        <Label text="or" style="-fx-text-fill: #3a3a55; -fx-font-size: 12px;" />
        <Separator HBox.hgrow="ALWAYS" />
      </HBox>

      <!-- Register Button -->
      <Button fx:id="registerButton" text="Create New Account" onAction="#handleRegister"
        maxWidth="Infinity"
        style="-fx-background-color: transparent;
               -fx-border-color: rgba(255,255,255,0.12);
               -fx-border-radius: 12; -fx-background-radius: 12;
               -fx-border-width: 1; -fx-text-fill: #8b8ba0;
               -fx-font-size: 14px; -fx-padding: 12;
               -fx-cursor: hand;" />

      <!-- Forgot Password Button -->
      <Button fx:id="forgotPasswordButton" text="Forgot Password?" onAction="#handleForgotPassword"
        maxWidth="Infinity"
        style="-fx-background-color: transparent;
               -fx-border-color: transparent;
               -fx-text-fill: #c9a84c;
               -fx-font-size: 13px; -fx-padding: 4;
               -fx-cursor: hand;
               -fx-underline: true;" />

      <Label fx:id="errorLabel" text=""
        style="-fx-text-fill: #ff5c5c; -fx-font-size: 12px;" />
    </VBox>
  </VBox>
</StackPane>
