<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.shape.*?>

<!--
  Customer Dashboard — ASH dark luxury theme.
  Sidebar + main content layout mirroring the HTML GUI design.
  All fx:id and onAction handlers preserved exactly as in the original controller.
-->
<BorderPane xmlns:fx="http://javafx.com/fxml"
  fx:controller="org.musicStore.gui.CustomerDashboard"
  prefWidth="1200" prefHeight="780"
  style="-fx-background-color: #1a0a2e;">

  <!-- ═══════════════════ SIDEBAR ═══════════════════ -->
  <left>
    <VBox prefWidth="220" minWidth="220"
      style="-fx-background-color: #1e1035;
             -fx-border-color: rgba(255,255,255,0.06);
             -fx-border-width: 0 1 0 0;">

      <!-- Brand -->
      <HBox spacing="10" alignment="CENTER_LEFT"
        style="-fx-padding: 22 18; -fx-border-color: rgba(255,255,255,0.06); -fx-border-width: 0 0 1 0;">
        <StackPane>
          <Rectangle width="36" height="36" arcWidth="10" arcHeight="10"
            style="-fx-fill: linear-gradient(to bottom right, #c9a84c, #7c5cbf);" />
          <Label text="🎸" style="-fx-font-size: 16px;" />
        </StackPane>
        <VBox spacing="2">
          <Label text="ASH"
            style="-fx-font-family: 'Georgia'; -fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #e8e8f0;" />
          <Label text="CUSTOMER"
            style="-fx-font-size: 9px; -fx-text-fill: #c9a84c; -fx-font-weight: bold;" />
        </VBox>
      </HBox>

      <!-- Nav -->
      <VBox spacing="2" style="-fx-padding: 14 10;">
        <Label text="BROWSE"
          style="-fx-font-size: 9px; -fx-text-fill: #3a3a55; -fx-font-weight: bold; -fx-padding: 6 8 4 8;" />
        <Button text="🎵  Shop" onAction="#handleBack"
          maxWidth="Infinity"
          style="-fx-background-color: rgba(201,168,76,0.10);
                 -fx-text-fill: #c9a84c; -fx-font-size: 13px;
                 -fx-background-radius: 10; -fx-cursor: hand;
                 -fx-padding: 10 12; -fx-alignment: CENTER_LEFT;" />
        <Button text="📦  Order History" onAction="#handleViewHistory"
          maxWidth="Infinity"
          style="-fx-background-color: transparent;
                 -fx-text-fill: #6b6b85; -fx-font-size: 13px;
                 -fx-background-radius: 10; -fx-cursor: hand;
                 -fx-padding: 10 12; -fx-alignment: CENTER_LEFT;" />
        <Label text="ACCOUNT"
          style="-fx-font-size: 9px; -fx-text-fill: #3a3a55; -fx-font-weight: bold; -fx-padding: 14 8 4 8;" />
        <Button text="✏  Edit Profile" onAction="#handleEditProfile"
          maxWidth="Infinity"
          style="-fx-background-color: transparent;
                 -fx-text-fill: #6b6b85; -fx-font-size: 13px;
                 -fx-background-radius: 10; -fx-cursor: hand;
                 -fx-padding: 10 12; -fx-alignment: CENTER_LEFT;" />
        <Button text="🚪  Logout" onAction="#handleLogout"
          maxWidth="Infinity"
          style="-fx-background-color: transparent;
                 -fx-text-fill: #6b6b85; -fx-font-size: 13px;
                 -fx-background-radius: 10; -fx-cursor: hand;
                 -fx-padding: 10 12; -fx-alignment: CENTER_LEFT;" />
      </VBox>

      <Region VBox.vgrow="ALWAYS" />

      <!-- User Footer -->
      <HBox spacing="10" alignment="CENTER_LEFT"
        style="-fx-padding: 14 16; -fx-background-color: rgba(255,255,255,0.02);
               -fx-border-color: rgba(255,255,255,0.06); -fx-border-width: 1 0 0 0;">
        <StackPane>
          <Circle radius="16"
            style="-fx-fill: linear-gradient(to bottom right, #7c5cbf, #c9a84c);" />
          <Label text="C" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: white;" />
        </StackPane>
        <VBox spacing="2">
          <Label fx:id="customerNameLabel" text="Customer"
            style="-fx-font-size: 12px; -fx-font-weight: 600; -fx-text-fill: #e8e8f0;" />
          <Label fx:id="pointsLabel" text="⭐ 0 Points"
            style="-fx-font-size: 11px; -fx-text-fill: #c9a84c;" />
        </VBox>
      </HBox>
    </VBox>
  </left>

  <!-- ═══════════════════ MAIN CONTENT ═══════════════════ -->
  <center>
    <VBox style="-fx-background-color: #1a0a2e;">

      <!-- Topbar -->
      <HBox alignment="CENTER_LEFT" spacing="12"
        style="-fx-padding: 0 24; -fx-min-height: 64; -fx-max-height: 64;
               -fx-background-color: rgba(26,10,46,0.95);
               -fx-border-color: rgba(255,255,255,0.06); -fx-border-width: 0 0 1 0;">
        <Label text="Shop"
          style="-fx-font-family: 'Georgia'; -fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #e8e8f0;" />
        <Region HBox.hgrow="ALWAYS" />
        <!-- Search Bar -->
        <HBox spacing="8" alignment="CENTER"
          style="-fx-background-color: #1e1035;
                 -fx-border-color: rgba(255,255,255,0.08);
                 -fx-border-radius: 10; -fx-background-radius: 10;
                 -fx-border-width: 1; -fx-padding: 8 14;">
          <Label text="🔍" style="-fx-text-fill: #6b6b85; -fx-font-size: 13px;" />
          <TextField fx:id="searchField" promptText="Search instruments &amp; brands..."
            prefWidth="240"
            style="-fx-background-color: transparent; -fx-border-width: 0;
                   -fx-text-fill: #e8e8f0; -fx-prompt-text-fill: #3a3a55; -fx-font-size: 13px;" />
        </HBox>
        <Button text="Search" onAction="#handleSearch"
          style="-fx-background-color: #c9a84c; -fx-text-fill: #1a0a2e;
                 -fx-font-weight: bold; -fx-font-size: 13px;
                 -fx-background-radius: 10; -fx-cursor: hand; -fx-padding: 8 18;" />
        <Button fx:id="backButton" text="← All" onAction="#handleBack"
          visible="false" managed="false"
          style="-fx-background-color: rgba(255,255,255,0.06);
                 -fx-border-color: rgba(255,255,255,0.10);
                 -fx-border-radius: 10; -fx-background-radius: 10;
                 -fx-border-width: 1; -fx-text-fill: #8b8ba0;
                 -fx-font-size: 13px; -fx-cursor: hand; -fx-padding: 8 14;" />
      </HBox>

      <!-- Filter Row -->
      <HBox spacing="10" alignment="CENTER_LEFT"
        style="-fx-padding: 12 24;
               -fx-background-color: rgba(30,16,53,0.8);
               -fx-border-color: rgba(255,255,255,0.05); -fx-border-width: 0 0 1 0;">
        <Label text="Filter:"
          style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #6b6b85;" />
        <TextField fx:id="filterBrandField" promptText="Brand..."
          prefWidth="110" onKeyReleased="#handleFilter"
          style="-fx-background-color: rgba(255,255,255,0.04);
                 -fx-border-color: rgba(255,255,255,0.08);
                 -fx-border-radius: 8; -fx-background-radius: 8; -fx-border-width: 1;
                 -fx-text-fill: #e8e8f0; -fx-prompt-text-fill: #3a3a55;
                 -fx-font-size: 12px; -fx-padding: 7 10;" />
        <TextField fx:id="filterCategoryField" promptText="Category..."
          prefWidth="110" onKeyReleased="#handleFilter"
          style="-fx-background-color: rgba(255,255,255,0.04);
                 -fx-border-color: rgba(255,255,255,0.08);
                 -fx-border-radius: 8; -fx-background-radius: 8; -fx-border-width: 1;
                 -fx-text-fill: #e8e8f0; -fx-prompt-text-fill: #3a3a55;
                 -fx-font-size: 12px; -fx-padding: 7 10;" />
        <TextField fx:id="filterMinPriceField" promptText="Min $"
          prefWidth="90" onKeyReleased="#handleFilter"
          style="-fx-background-color: rgba(255,255,255,0.04);
                 -fx-border-color: rgba(255,255,255,0.08);
                 -fx-border-radius: 8; -fx-background-radius: 8; -fx-border-width: 1;
                 -fx-text-fill: #e8e8f0; -fx-prompt-text-fill: #3a3a55;
                 -fx-font-size: 12px; -fx-padding: 7 10;" />
        <TextField fx:id="filterMaxPriceField" promptText="Max $"
          prefWidth="90" onKeyReleased="#handleFilter"
          style="-fx-background-color: rgba(255,255,255,0.04);
                 -fx-border-color: rgba(255,255,255,0.08);
                 -fx-border-radius: 8; -fx-background-radius: 8; -fx-border-width: 1;
                 -fx-text-fill: #e8e8f0; -fx-prompt-text-fill: #3a3a55;
                 -fx-font-size: 12px; -fx-padding: 7 10;" />
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="statusLabel" text="Welcome to ASH Store!"
          style="-fx-text-fill: #6b6b85; -fx-font-style: italic; -fx-font-size: 12px;" />
      </HBox>

      <!-- Products + Cart split -->
      <HBox VBox.vgrow="ALWAYS" spacing="0">

        <!-- Product Table Area -->
        <VBox HBox.hgrow="ALWAYS" spacing="0"
          style="-fx-padding: 20 16 16 24;">
          <Label text="Available Instruments"
            style="-fx-font-family: 'Georgia'; -fx-font-size: 16px;
                   -fx-font-weight: bold; -fx-text-fill: #e8e8f0; -fx-padding: 0 0 12 0;" />
          <ScrollPane fx:id="productScrollPane" VBox.vgrow="ALWAYS" fitToWidth="true"
            style="-fx-background-color: transparent; -fx-background: transparent;
                   -fx-border-width: 0; -fx-padding: 0;">
            <FlowPane fx:id="productGrid" hgap="16" vgap="16"
              style="-fx-background-color: transparent; -fx-padding: 4 4 16 4;">
            </FlowPane>
          </ScrollPane>

          <!-- Add to Cart Button -->
          <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 14 0 0 0;">
            <Button text="＋  Add to Cart" onAction="#handleAddToCart"
              style="-fx-background-color: #3ddc84; -fx-text-fill: #1a0a2e;
                     -fx-font-weight: bold; -fx-font-size: 13px;
                     -fx-background-radius: 10; -fx-cursor: hand; -fx-padding: 10 22;" />
            <Button text="✏  Edit Cart" onAction="#handleEditCart"
              style="-fx-background-color: rgba(124,92,191,0.18);
                     -fx-border-color: rgba(124,92,191,0.4);
                     -fx-border-radius: 10; -fx-background-radius: 10;
                     -fx-border-width: 1; -fx-text-fill: #9b7fe0;
                     -fx-font-size: 13px; -fx-cursor: hand; -fx-padding: 10 18;" />
          </HBox>
        </VBox>

        <!-- Cart Panel -->
        <VBox prefWidth="300" minWidth="280"
          style="-fx-background-color: #1e1035;
                 -fx-border-color: rgba(255,255,255,0.06);
                 -fx-border-width: 0 0 0 1;
                 -fx-padding: 20 18 18 18;"
          spacing="12">
          <Label text="🛒  Your Cart"
            style="-fx-font-family: 'Georgia'; -fx-font-size: 16px;
                   -fx-font-weight: bold; -fx-text-fill: #e8e8f0;" />
          <ListView fx:id="cartListView" VBox.vgrow="ALWAYS"
            style="-fx-background-color: rgba(255,255,255,0.02);
                   -fx-border-color: rgba(255,255,255,0.06);
                   -fx-border-radius: 10; -fx-background-radius: 10;
                   -fx-border-width: 1;
                   -fx-text-fill: #e8e8f0;" />

          <!-- Order Summary Card -->
          <VBox spacing="10"
            style="-fx-background-color: rgba(255,255,255,0.03);
                   -fx-border-color: rgba(201,168,76,0.2);
                   -fx-border-radius: 12; -fx-background-radius: 12;
                   -fx-border-width: 1; -fx-padding: 16;">
            <Label text="Order Summary"
              style="-fx-font-size: 11px; -fx-font-weight: bold;
                     -fx-text-fill: #6b6b85; -fx-letter-spacing: 1px;" />
            <Separator style="-fx-background-color: rgba(255,255,255,0.06);" />
            <Label fx:id="totalLabel" text="Total: $0.00"
              style="-fx-font-family: 'Courier New'; -fx-font-size: 20px;
                     -fx-font-weight: bold; -fx-text-fill: #c9a84c;" />
          </VBox>

          <!-- Checkout Button -->
          <Button text="Checkout  →" onAction="#handleCheckout"
            maxWidth="Infinity"
            style="-fx-background-color: linear-gradient(to right, #c9a84c, #9a7030);
                   -fx-text-fill: #1a0a2e; -fx-font-weight: bold;
                   -fx-font-size: 14px; -fx-padding: 13;
                   -fx-background-radius: 12; -fx-cursor: hand;" />
        </VBox>
      </HBox>
    </VBox>
  </center>
</BorderPane>